# ECROS 5400 UV Simulator — Сценарии переходов (USER FLOW MAP)

> Файл содержит две диаграммы:
> - **Блок 1 (Уровень B)** — операционная карта: все экраны + кнопки + guard-условия
> - **Блок 2 (Уровень C)** — 6 пользовательских сценариев (шаги + псевдосостояния)

---

## Диаграмма 1 — Уровень B: Полная операционная карта

```mermaid
stateDiagram-v2
    direction LR

    [*] --> greeting

    %% ─── ЗАГРУЗКА ───────────────────────────────────────────────────────
    state "Загрузка" as BOOT {
        greeting --> diagnostic : авто
        diagnostic --> warmup : авто (тесты завершены)
        warmup --> main : ESC / авто
    }

    %% ─── ГЛАВНОЕ МЕНЮ ────────────────────────────────────────────────────
    main --> photometry           : ВВОД [mainIndex=0]
    main --> quantMain            : ВВОД [mainIndex=1]
    main --> kineticsMenu         : ВВОД [mainIndex=2]
    main --> multiWaveMenu        : ВВОД [mainIndex=3]
    main --> settings             : ВВОД [mainIndex=4]
    main --> fileRoot             : ФАЙЛ

    %% ─── ФАЙЛОВЫЙ МЕНЕДЖЕР ───────────────────────────────────────────────
    fileRoot --> fileList         : ВВОД
    fileRoot --> main             : ESC [previousScreen=main]
    fileList --> fileActionMenu   : ВВОД [список не пуст]
    fileList --> fileRoot         : ESC [previousScreen=main]
    fileList --> previousScreen   : ESC [previousScreen≠main]
    fileActionMenu --> warning    : ВВОД [action=ОТКРЫТЬ]
    fileActionMenu --> input      : ВВОД [action=ПЕРЕИМЕНОВАТЬ]
    fileActionMenu --> fileList   : ВВОД [action=УДАЛИТЬ] / ESC
    fileActionMenu --> warning    : ВВОД [action=ЭКСПОРТ]

    %% ─── УНИВЕРСАЛЬНЫЙ ВВОД ──────────────────────────────────────────────
    input --> returnScreen        : ВВОД (применить значение)
    input --> returnScreen        : ESC (сбросить)

    %% ─── ПРЕДУПРЕЖДЕНИЕ ──────────────────────────────────────────────────
    warning --> warningReturn     : ВВОД / ESC

    %% ─── ДИАЛОГ СОХРАНЕНИЯ (input-режим saveName) ────────────────────────
    saveDialog --> previousScreen : ВВОД [saveFile атомарно]
    saveDialog --> previousScreen : ESC

    %% ─── ФОТОМЕТРИЯ ──────────────────────────────────────────────────────
    photometry --> input          : GOTOλ → inputTarget=wavelength
    photometry --> photometryValue: SET
    photometry --> photometryGraph: DOWN [курсор на посл. записи]
    photometry --> saveDialog     : ФАЙЛ [есть результаты]
    photometry --> fileList       : ФАЙЛ [нет результатов]
    photometry --> main           : ESC
    photometryValue --> input     : ВВОД [index=Парал. измерения]
    photometryValue --> photometry: ВВОД [index=А|%Т|ЭНЕРГИЯ] / ESC
    photometryGraph --> photometry: ESC
    photometryGraph --> saveDialog: ФАЙЛ

    %% ─── КОЛИЧЕСТВЕННЫЙ АНАЛИЗ ───────────────────────────────────────────
    quantMain --> calibrationSetupStandards : ВВОД [index=0]
    quantMain --> quantCoef       : ВВОД [index=1]
    quantMain --> quantUnits      : ВВОД [index=2]
    quantMain --> fileList        : ФАЙЛ
    quantMain --> main            : ESC

    quantUnits --> quantMain      : ВВОД / ESC

    quantCoef --> warning         : SET
    quantCoef --> input           : 1 → inputTarget=quantK
    quantCoef --> input           : 2 → inputTarget=quantB
    quantCoef --> input           : GOTOλ → inputTarget=wavelength
    quantCoef --> saveDialog      : ФАЙЛ
    quantCoef --> quantMain       : ESC

    calibrationSetupStandards --> calibrationSetupParallels : ВВОД
    calibrationSetupStandards --> quantMain                 : ESC
    calibrationSetupParallels --> calibrationPlan           : ВВОД [buildCalibrationPlan]
    calibrationSetupParallels --> calibrationSetupStandards : ESC

    calibrationPlan --> calibrationStep    : ВВОД
    calibrationPlan --> calibrationJournal : DOWN [есть результаты]
    calibrationPlan --> fileList           : ФАЙЛ
    calibrationPlan --> quantMain          : ESC

    calibrationStep --> calibrationJournal : ВВОД/START→STOP [измерение]
    calibrationStep --> saveDialog         : ФАЙЛ
    calibrationStep --> calibrationPlan    : ESC

    calibrationJournal --> calibrationStep  : ВВОД [есть незавер. шаги]
    calibrationJournal --> calibrationGraph : ВВОД [все шаги завершены] / DOWN [конец]
    calibrationJournal --> calibrationStep  : START→STOP [переизмерить]
    calibrationJournal --> calibrationStep  : CLEAR [удалить]
    calibrationJournal --> saveDialog       : ФАЙЛ
    calibrationJournal --> calibrationPlan  : ESC

    calibrationGraph --> calibrationJournal : ESC
    calibrationGraph --> saveDialog         : ФАЙЛ

    %% ─── КИНЕТИКА ────────────────────────────────────────────────────────
    kineticsMenu --> input         : ВВОД [index=1] → inputTarget=kinUpper
    kineticsMenu --> input         : ВВОД [index=2] → inputTarget=kinLower
    kineticsMenu --> input         : ВВОД [index=3] → inputTarget=kinDuration
    kineticsMenu --> kineticsRun   : ВВОД [index=4 ПУСК] startKinetics
    kineticsMenu --> input         : GOTOλ → inputTarget=wavelength
    kineticsMenu --> fileList      : ФАЙЛ
    kineticsMenu --> main          : ESC

    kineticsRun --> kineticsGraph  : DOWN
    kineticsRun --> kineticsMenu   : START→STOP [stopKinetics] / ESC
    kineticsRun --> saveDialog     : ФАЙЛ
    kineticsGraph --> kineticsRun  : ESC
    kineticsGraph --> saveDialog   : ФАЙЛ

    %% ─── МНОГОВОЛНОВОЙ АНАЛИЗ ────────────────────────────────────────────
    multiWaveMenu --> input            : ВВОД [Длины волн] → inputTarget=multiWaveCount
    multiWaveMenu --> multiWaveSetup   : (после ввода кол-ва)
    multiWaveMenu --> input            : ВВОД [Парал. изм.] → inputTarget=parallelCount
    multiWaveMenu --> photometryValue  : ВВОД [Аналит. сигнал]
    multiWaveMenu --> quantUnits       : ВВОД [Единицы]
    multiWaveMenu --> multiWaveRun     : ВВОД [ПУСК] startMultiWave
    multiWaveMenu --> input            : GOTOλ
    multiWaveMenu --> fileList         : ФАЙЛ
    multiWaveMenu --> main             : ESC

    multiWaveSetup --> input           : ВВОД [строка λN]
    multiWaveSetup --> multiWaveMenu   : ESC

    multiWaveRun --> multiWaveJournal  : ВВОД/START→STOP [измерение всех λ]
    multiWaveRun --> saveDialog        : ФАЙЛ [есть результаты]
    multiWaveRun --> fileList          : ФАЙЛ [нет результатов]
    multiWaveRun --> multiWaveMenu     : ESC

    multiWaveJournal --> multiWaveRun  : ВВОД / ESC
    multiWaveJournal --> multiWaveGraph: DOWN [конец]
    multiWaveJournal --> saveDialog    : ФАЙЛ
    multiWaveGraph --> multiWaveJournal: ESC
    multiWaveGraph --> saveDialog      : ФАЙЛ

    %% ─── НАСТРОЙКИ ───────────────────────────────────────────────────────
    settings --> warning    : ВВОД [index=2 Темн. ток]
    settings --> warning    : ВВОД [index=3 Калибр. λ]
    settings --> version    : ВВОД [index=4]
    settings --> greeting   : ВВОД [index=5 Сброс → resetAll]
    settings --> main       : ESC

    version --> settings    : ВВОД / ESC
```

