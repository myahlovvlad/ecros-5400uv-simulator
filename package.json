{
  "name": "ecros-5400uv-simulator",
  "version": "2.0.0",
  "description": "Симулятор спектрофотометра ЭКРОС-5400УФ с Clean Architecture",
  "type": "module",
  "main": "main.jsx",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/ --ext .js,.jsx",
    "lint:fix": "eslint src/ --ext .js,.jsx --fix",
    "audit:glyphs": "node scripts/glyph-audit.mjs",
    "docs:screens": "node scripts/generate-screen-docs.mjs",
    "docs:screens:html": "node scripts/generate-screen-docs.mjs --html-only",
    "typecheck": "tsc --noEmit",
    "start": "node scripts/start.js"
  },
  "keywords": [
    "ecros",
    "spectrophotometer",
    "simulator",
    "lab-equipment"
  ],
  "author": "myahlovvlad",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/myahlovvlad/ecros-5400uv-simulator.git"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
