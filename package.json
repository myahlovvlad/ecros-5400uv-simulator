{
  "name": "ecros-5400uv-simulator",
  "version": "2.0.0",
  "description": "Симулятор спектрофотометра ЭКРОС-5400УФ с Clean Architecture",
  "type": "module",
  "main": "src/main.jsx",
  "scripts": {
    "dev": "vite --config config/vite.config.js",
    "build": "vite build --config config/vite.config.js",
    "preview": "vite preview --config config/vite.config.js",
    "test": "vitest --config config/vitest.config.js",
    "test:coverage": "vitest --config config/vitest.config.js --coverage",
    "test:unit:qa": "vitest --config config/vitest.config.js --run --reporter=json --outputFile=qa-artifacts/unit/vitest-report.json",
    "test:ui": "playwright test --config config/playwright.config.js",
    "test:ui:update-snapshots": "playwright test --config config/playwright.config.js --update-snapshots",
    "test:ui:headed": "playwright test --config config/playwright.config.js --headed",
    "test:ui:debug": "playwright test --config config/playwright.config.js --debug",
    "qa:report": "node scripts/generate-qa-report.mjs",
    "qa:full": "npm run test:unit:qa && npm run test:ui && npm run qa:report",
    "lint": "eslint --config config/eslint.config.cjs src/ --ext .js,.jsx",
    "lint:fix": "eslint --config config/eslint.config.cjs src/ --ext .js,.jsx --fix",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "start": "node scripts/start.js"
  },
  "keywords": [
    "ecros",
    "spectrophotometer",
    "simulator",
    "lab-equipment"
  ],
  "author": "myahlovvlad",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/myahlovvlad/ecros-5400uv-simulator.git"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
